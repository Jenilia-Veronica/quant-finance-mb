   "source": [
    "Simple Interest Calculator(principal is 1000, annual interest rate is 0.05, time in years is 3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "5fa70879",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "future value:  1150.0\n",
      "interest:  150.0\n"
     ]
    }
   ],
   "source": [
    "p = 1000\n",
    "r = 0.05\n",
    "t = 3\n",
    "fv_simple = p*(1+r*t)\n",
    "interest = fv_simple-p\n",
    "print(\"future value: \", fv_simple)\n",
    "print(\"interest: \", interest)"
   ]
  },
